# ─── Turso DB (libSQL) ───────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token-here

# ─── Crawler ─────────────────────────────────────────────────────────────────
CRAWLER_DELAY_MIN=2000
CRAWLER_DELAY_MAX=5000
CRAWLER_MAX_CONCURRENCY=3
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30000
SPEEDHOME_BASE_URL=https://speedhome.com

# ─── Auth ────────────────────────────────────────────────────────────────────
# Required in production. Without this, admin endpoints are denied.
ADMIN_TOKEN=change-me

# Cron secret for /api/cron/refresh — required for scheduled refresh
CRON_SECRET=change-me

# ─── Email alerts (Point 6 — optional) ───────────────────────────────────────
# Resend API key (https://resend.com). When unset, alert emails are skipped.
RESEND_API_KEY=
ALERT_FROM_EMAIL=Estate Insight <alerts@estate-insight.app>

# ─── Public site URL (used by sitemap, robots, OG metadata) ──────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com
